{
  "include": [
    "./src/App.tsx",
    "./src/GameApp.tsx",
    "./src/main.tsx",
    "./src/audio/**/*.ts",
    "./src/components/*.tsx",
    "./src/game/**/*.ts",
    "./src/scene/**/*.tsx",
    "./src/svg.d.ts",
    "./src/three-fiber-types.d.ts",
    "./src/vite-env.d.ts"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
